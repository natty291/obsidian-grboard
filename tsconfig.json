{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2018", "dom"],
    "moduleResolution": "node",
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["**/*.ts"]
  "exclude": ["webapp/**"]
}
